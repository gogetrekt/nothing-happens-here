{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "(?<__isr_route>/__nuxt_content/(?:.*))",
      "dest": "/__fallback"
    },
    {
      "src": "/write",
      "dest": "/write"
    },
    {
      "src": "/sanctum/new",
      "dest": "/sanctum/new"
    },
    {
      "src": "/sanctum-login",
      "dest": "/sanctum-login"
    },
    {
      "src": "/sanctum",
      "dest": "/sanctum"
    },
    {
      "src": "/editor",
      "dest": "/editor"
    },
    {
      "src": "/archive",
      "dest": "/archive"
    },
    {
      "src": "/api/poems",
      "dest": "/api/poems"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/__nuxt_content/poems/query",
      "dest": "/__nuxt_content/poems/query"
    },
    {
      "src": "/__nuxt_content/info/sql_dump.txt",
      "dest": "/__nuxt_content/info/sql_dump.txt"
    },
    {
      "src": "/__nuxt_content/info/query",
      "dest": "/__nuxt_content/info/query"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/sanctum/edit/(?<id>[^/]+)",
      "dest": "/sanctum/edit/[id]"
    },
    {
      "src": "/poem/(?<slug>[^/]+)",
      "dest": "/poem/[slug]"
    },
    {
      "src": "/editor/(?<id>[^/]+)",
      "dest": "/editor/[id]"
    },
    {
      "src": "/api/poems/slug/(?<slug>[^/]+)",
      "dest": "/api/poems/slug/[slug]"
    },
    {
      "src": "/api/poems/(?<id>[^/]+)",
      "dest": "/api/poems/[id]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}